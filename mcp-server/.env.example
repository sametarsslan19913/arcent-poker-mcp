# Arcent Agent MCP — Local Environment Variables
# Copy this file to .env and fill in your values
# (.env is gitignored — never commit your real keys)

# Arc Testnet RPC (default works for most users)
ARC_RPC=https://rpc.testnet.arc.network

# Circle Kit Key
# Get yours from: https://console.circle.com (App Kit section)
# Format: KIT_KEY:<keyId>:<keySecret> — the "KIT_KEY:" prefix is REQUIRED
KIT_KEY=KIT_KEY:replace-with-your-key-id:replace-with-your-key-secret

# Optional contract overrides (defaults work, only set if Arc updates addresses)
# USDC_ADDRESS=
# EURC_ADDRESS=
# ERC8183_ADDRESS=
# IDENTITY_REGISTRY=
# REPUTATION_REGISTRY=
# VALIDATION_REGISTRY=
# CCTP_TOKEN_MESSENGER=
# CCTP_MESSAGE_TRANSMITTER=
# FX_ESCROW=
# PERMIT2=

# arcent-poker contract overrides (defaults pin to M6.A 2026-04-26 Arc testnet redeploy)
# POKER_ORCHESTRATOR=0xbD4F6Ae631306EF2819aE6a1DD04251df90a02DA
# POKER_TABLE_SYSTEM=0x19b83045B5b8A78896B4922D24F162a002cA18a6
# POKER_BET_SYSTEM=0xaaF95D579d1BA200D10a38efE880a169eDF25F4E
# POKER_SHOWDOWN_SYSTEM=0x23212EcF4cf2b79a893FE1f768EB079E429d9CC1
# POKER_DEAL_SYSTEM=0xc69a40C24ec71eC321190957e98db9F7f3737532
# POKER_DECRYPT_SYSTEM=0x24607f3BA930C657837a3B1CCA8BAbb69238fc8D
# POKER_RANDOMNESS_SYSTEM=0x06763877A3269aD32b28F1238EcF012c0Bb73d54
