# Arcent Agent MCP — Local Environment Variables
# Copy this file to .env and fill in your values
# (.env is gitignored — never commit your real keys)

# Arc Testnet RPC (default works for most users)
ARC_RPC=https://rpc.testnet.arc.network

# Circle Kit Key
# Get yours from: https://console.circle.com (App Kit section)
# Format: KIT_KEY:<keyId>:<keySecret> — the "KIT_KEY:" prefix is REQUIRED
KIT_KEY=KIT_KEY:replace-with-your-key-id:replace-with-your-key-secret

# Optional contract overrides (defaults work, only set if Arc updates addresses)
# USDC_ADDRESS=
# EURC_ADDRESS=
# ERC8183_ADDRESS=
# IDENTITY_REGISTRY=
# REPUTATION_REGISTRY=
# VALIDATION_REGISTRY=
# CCTP_TOKEN_MESSENGER=
# CCTP_MESSAGE_TRANSMITTER=
# FX_ESCROW=
# PERMIT2=

# arcent-poker contract addresses (REQUIRED — no defaults).
#
# Adresler her redeploy'da degisiyor. En guncel canli adresler:
#   https://github.com/sametarsslan19913/arcent-poker/blob/main/docs/DEPLOYMENT.md
#
# Son redeploy: 2026-05-11 deep-audit refactor + USDC-only.
POKER_ORCHESTRATOR=0x2aCF2861151E7F6f4B1CE510a67627c1f0CdAA8e
POKER_TABLE_SYSTEM=0xb184b74012308BA979df22Aaf83c6B346bd605f1
POKER_BET_SYSTEM=0x16c12A7377C697d1Fc3d3682EF5F0D0948679e3f
POKER_SHOWDOWN_SYSTEM=0x896169E0EB8CEcAe0E1c7e08d42E11457b60C6b3
POKER_DEAL_SYSTEM=0x66eD6BF529C94B8Cc378b7F6a3824eD88A862aA1
POKER_DECRYPT_SYSTEM=0x2f9F6f639E2326d2b3589E1eb826fB5E5c794EAB
# Not: POKER_RANDOMNESS_SYSTEM 2026-05-10 audit'inde legacy/'a tasindi
# (Arc block.prevrandao = 0 -> kullanilamaz, hicbir sistem cagirmiyordu).
